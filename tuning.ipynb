    "\n",
    "\n",
    "import os\n",
    "\n",
    "FOLDER = r\"C:\\Users\\ahmed\\Desktop\\birdsbegone\\test\\labels\"  # ← change this\n",
    "\n",
    "count = 0\n",
    "for fname in os.listdir(FOLDER):\n",
    "    if fname.endswith(\".txt\"):\n",
    "        open(os.path.join(FOLDER, fname), \"w\").close()\n",
    "        count += 1\n",
    "\n",
    "print(f\"Emptied {count} txt files\")\n"
   ]
